# ===========================================
# KORVEX Pool - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ===========================================
# DATABASE
# ===========================================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=korvex_pool
DB_USER=ergo
DB_PASS=                    # REQUIRED - PostgreSQL password

# ===========================================
# ERGO NODE
# ===========================================
ERGO_NODE_URL=http://127.0.0.1:9053
ERGO_NODE_API_KEY=          # REQUIRED - Ergo node API key

# ===========================================
# POOL CONFIGURATION
# ===========================================
POOL_ADDRESS=               # REQUIRED - Pool wallet address (receives fees)
POOL_FEE=0.01               # 1% fee
STRATUM_PORT=3416
API_PORT=4000

# ===========================================
# PPLNS
# ===========================================
PPLNS_FACTOR=2              # Window = factor * network difficulty

# ===========================================
# PAYOUTS
# ===========================================
WALLET_PASS=                # REQUIRED - Wallet password for auto-payouts
MIN_PAYOUT_NANO=1000000000  # 1 ERG minimum
PAYOUT_CONFIRMATIONS=720    # ~24 hours
PAYOUT_MAX_PER_BATCH=20
PAYOUT_INTERVAL_MINUTES=10
PAYOUT_MAX_RETRIES=3

# ===========================================
# SOLO MINING
# ===========================================
STRATUM_SOLO_PORT=3417
SOLO_FEE=0.015              # 1.5% fee

# ===========================================
# ADMIN
# ===========================================
# ADMIN_PASSWORD=           # Admin panel password

# ===========================================
# DISCORD ALERTS (optional)
# ===========================================
# DISCORD_WEBHOOK_URL=      # Discord webhook for pool alerts

# ===========================================
# MONERO (XMR) - Processus SEPARE
# ===========================================
# Daemon monerod
XMR_DAEMON_URL=http://127.0.0.1:18081

# Wallet RPC (monero-wallet-rpc)
XMR_WALLET_RPC_URL=http://127.0.0.1:18082

# Pool XMR
XMR_POOL_ADDRESS=           # REQUIRED - Monero wallet address (receives fees)
XMR_POOL_FEE=0.01           # 1% fee
XMR_STRATUM_PORT=3418       # Port stratum Monero PPLNS
XMR_API_PORT=4100           # API port (Nginx proxies /api/xmr/*)

# PPLNS Monero
XMR_PPLNS_FACTOR=2          # Window = factor * network difficulty

# Payouts Monero
XMR_MIN_PAYOUT_PICO=100000000000  # 0.1 XMR minimum (en piconero)
XMR_PAYOUT_CONFIRMATIONS=60       # 60 blocs (~2h)
XMR_PAYOUT_INTERVAL_MINUTES=30    # Cycle paiement toutes les 30 min
